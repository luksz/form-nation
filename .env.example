# Copy to .env and fill in.
GEMINI_API_KEY=your-key-here

# Telegram bot (create one with @BotFather, then run: python -m app.telegram_bot)
TELEGRAM_BOT_TOKEN=

# Data retention: uploaded forms + filled outputs are deleted after this many hours
RETENTION_HOURS=24

# Where the bot finds the form-nation API
FORM_NATION_API=http://127.0.0.1:8477
