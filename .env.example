# Copy to .env and fill in.
GEMINI_API_KEY=your-key-here

# Telegram bot (create one with @BotFather, then run: python -m app.telegram_bot)
TELEGRAM_BOT_TOKEN=

# Data retention: uploaded forms + filled outputs are deleted after this many hours
RETENTION_HOURS=24

# Delivered PDFs are deleted from the Telegram chat after this many minutes (0 = keep)
DELETE_DELIVERED_MINUTES=60

# Redact NRIC/email/phone/account numbers before any LLM call (true/false)
REDACT_BEFORE_LLM=true

# Where the bot finds the form-nation API
FORM_NATION_API=http://127.0.0.1:8477

# --- production / deployment ---
# Access key protecting the web UI and API (leave empty to disable auth locally).
# Generate one with:  python3 -c "import secrets; print(secrets.token_urlsafe(24))"
APP_ACCESS_TOKEN=

# Public HTTPS address of the web UI (used in the bot's deep links)
PUBLIC_URL=http://127.0.0.1:8477

# Your domain, used by Caddy for automatic HTTPS (docker compose deploys)
DOMAIN=forms.example.com

# Max upload size in MB
MAX_UPLOAD_MB=20
